{"_vrs": {"version": 1}, "trace_id": "core-1659-load-skill-indexes-mgear-tools", "title": "Gateway load_skill must index maya-mgear tools even when backend search refresh is unavailable", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"kind": "skill", "query": "maya-mgear", "dcc_type": "maya", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
{"id": "load_maya_mgear_indexes_tools", "http": {"method": "POST", "path": "/v1/load_skill", "json": {"skill_name": "maya-mgear", "dcc_type": "maya"}}, "expect": {"status": 200, "body_contains_all": ["maya-mgear", "new_tool_slugs", "maya_mgear__inspect_mgear_environment"]}}
{"id": "find_loaded_mgear_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "mgear", "dcc_type": "maya", "loaded_only": true, "limit": 10}}, "expect": {"status": 200, "body_contains": "maya_mgear__inspect_mgear_environment"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "slug"}}
{"id": "call_loaded_mgear_tool", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:slug}}", "arguments": {}}}, "expect": {"status": 200, "body_contains": "mgear"}}
