{"_vrs": {"version": 1}, "trace_id": "core-1133-ui-control-gateway-rest", "title": "ui_control gateway REST discovery, describe metadata, and call envelope", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"query": "ui_control", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
{"id": "find_ui_control_snapshot", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "ui_control__snapshot", "limit": 1}}, "expect": {"status": 200, "body_contains": "ui_control__snapshot"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "slug"}}
{"id": "describe_ui_control_carries_metadata", "http": {"method": "POST", "path": "/v1/describe", "json": {"tool_slug": "{{capture:slug}}"}}, "expect": {"status": 200, "body_contains": "timeoutHintSecs"}}
{"id": "call_ui_control_preserves_output_envelope", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:slug}}", "arguments": {"session_id": "core-1133-vrs"}}}, "expect": {"status": 200, "json_subset": {"output": {"success": true}}}}
